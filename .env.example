# Server
PORT=3000
NODE_ENV=development

# IMPORTANT: Generate a strong random string for production!
# Run: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change-this-to-a-long-random-secret-string

# JWT expiration
JWT_ADMIN_EXPIRES_IN=24h
JWT_USER_EXPIRES_IN=7d

# CORS - comma-separated origins
# For Render + Vercel split: set to your Vercel domain
# Example: https://syria-travel.vercel.app
CORS_ORIGIN=*

# Upload
UPLOAD_DIR=public/uploads
UPLOAD_MAX_FILE_SIZE=5242880

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200
RATE_LIMIT_AUTH_MAX=20

# Database
DB_PATH=data.sqlite
DB_BACKUP_DIR=backups

# App URLs (critical for Render + Vercel split deployment)
# API_URL must be the full URL of the Render backend
# APP_URL is the frontend URL (Vercel)
# Example:
#   API_URL=https://syria-travel-backend.onrender.com
#   APP_URL=https://syria-travel.vercel.app
APP_URL=
API_URL=

# Logging (dev, combined, tiny, short)
LOG_LEVEL=dev

# SMTP (configured via admin panel, but can be set here as overrides)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM_EMAIL=noreply@syria-travel.com
SMTP_FROM_NAME=Syria Travel
