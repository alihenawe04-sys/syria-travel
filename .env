# Server
PORT=3000
NODE_ENV=production

# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=syria-travel-secret-key-2026

JWT_ADMIN_EXPIRES_IN=24h
JWT_USER_EXPIRES_IN=7d

# For all-in-one Render deployment (same origin)
CORS_ORIGIN=*

UPLOAD_DIR=/var/data/uploads
UPLOAD_MAX_FILE_SIZE=5242880

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200
RATE_LIMIT_AUTH_MAX=20

DB_PATH=/var/data/data.sqlite
DB_BACKUP_DIR=/var/data/backups

# Same-origin: leave empty
APP_URL=
API_URL=

LOG_LEVEL=combined

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM_EMAIL=noreply@syria-travel.com
SMTP_FROM_NAME=Syria Travel
